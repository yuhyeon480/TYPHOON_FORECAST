# ── 로컬 실행(python monitor.py)에서만 필요 ──────────────────────────
# apihub.kma.go.kr 회원가입(휴대폰 인증) 후 발급받은 인증키
KMA_AUTH_KEY=여기에_발급받은_인증키

# 로컬 무한루프 폴링 주기(초). GitHub Actions에서는 워크플로의 cron이 주기를
# 담당하므로 이 값은 로컬 테스트(python monitor.py)에서만 의미가 있음.
POLL_INTERVAL_SEC=600

# 상태 저장 파일 (JSON)
DB_PATH=typhoon_state.json

# ── FCM 푸시 설정 (로컬/Actions 공통) ────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id
FCM_TOPIC=typhoon_alerts

# 방법 A) 로컬: 서비스 계정 키 파일 경로
FCM_SERVICE_ACCOUNT_FILE=service-account.json

# 방법 B) GitHub Actions: 서비스 계정 키 JSON '내용'을 그대로 (Secrets로 주입, .env엔 비워둠)
FCM_SERVICE_ACCOUNT_JSON=

# 1이면 API 원문 응답을 그대로 로그에 출력 (파싱 형식 확인용)
DEBUG_RAW_RESPONSE=0
